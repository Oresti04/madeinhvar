# Sanity
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Public app URL for metadata, sitemap, and callback URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@yourdomain.com
RESEND_NOTIFY_EMAIL=owner@yourdomain.com

# Deployment notes: set these values in Vercel or your host
# Replace `yourdomain.com` with your actual sending domain once verified in Resend.
