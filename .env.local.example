# Copy this file to .env.local and fill in your values.

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook secret
# Get from Stripe dashboard → Webhooks after creating the endpoint
# Local testing: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Public app URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=you@yourdomain.com
RESEND_NOTIFY_EMAIL=you@yourdomain.com

# Keystatic admin password (protects /keystatic from public access)
KEYSTATIC_ADMIN_PASSWORD=strong_password_here
