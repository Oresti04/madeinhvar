# Copy this file to .env.local and fill in your values.

# Public app URL
NEXT_PUBLIC_SITE_URL=https://www.madeinhvar.com

# Teya payment
TEYA_API_KEY=your_teya_api_key_here
TEYA_API_URL=https://api.teya.com
TEYA_WEBHOOK_SECRET=your_teya_webhook_secret_here

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=orders@madeinhvar.com
RESEND_NOTIFY_EMAIL=madeinhvar@gmail.com

# Keystatic admin password (protects /keystatic from public access)
KEYSTATIC_ADMIN_PASSWORD=your_strong_password_here
